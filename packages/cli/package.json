    "zod": "^3.25.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@bahama/core": "0.1.0-alpha.6",
    "@bahama/provider-bahama-cloud": "0.1.0-alpha.6",
    "@bahama/provider-test": "0.1.0-alpha.6",
    "@bahama/provider-kit": "0.1.0-alpha.6",
    "@bahama/provider-local": "0.1.0-alpha.6",
    "@bahama/provider-neon": "0.1.0-alpha.6",
