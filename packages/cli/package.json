  "description": "Bahama: the agent-native infrastructure CLI. Declarative intent in bahama.yaml, deterministic plans out, verified execution against your own provider accounts.",
  "homepage": "https://github.com/bahamaAI/bahama#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bahamaAI/bahama.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/bahamaAI/bahama/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "bahama": "dist/bin.js"
  },
  "files": [
    "dist/bin.js",
    "dist/bin.js.LEGAL.txt",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b && node scripts/build.mjs",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.6.0",
    "fflate": "^0.8.2",
